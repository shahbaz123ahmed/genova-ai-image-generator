# Root level - ignore env files everywhere
.env
.env*
*.env

# Frontend (Next.js) - already covered in frontend/.gitignore, but extra safety
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/

# Backend (Python)
venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# General
node_modules/
dist/
build/
*.log
.DS_Store